{
    "name": "duncanmcclean/statamic-cargo",
    "description": "Comprehensive e-commerce addon for Statamic. Build bespoke e-commerce sites without the complexity.",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "DuncanMcClean\\Cargo\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests",
            "Tests\\Fixtures\\": "tests/__fixtures__/app"
        }
    },
    "extra": {
        "download-dist": [
            {
                "url": "https://github.com/duncanmcclean/statamic-cargo/releases/download/{$version}/dist.tar.gz",
                "path": "resources/dist"
            },
            {
                "url": "https://github.com/duncanmcclean/statamic-cargo/releases/download/{$version}/dist-checkout.tar.gz",
                "path": "resources/dist-checkout"
            }
        ],
        "statamic": {
            "name": "Cargo",
            "slug": "cargo",
            "description": "Comprehensive e-commerce addon for Statamic. Build bespoke e-commerce sites without the complexity."
        },
        "laravel": {
            "providers": [
                "DuncanMcClean\\Cargo\\ServiceProvider",
                "DuncanMcClean\\Cargo\\Discounts\\DiscountServiceProvider",
                "DuncanMcClean\\Cargo\\Orders\\OrderServiceProvider",
                "DuncanMcClean\\Cargo\\Payments\\PaymentServiceProvider",
                "DuncanMcClean\\Cargo\\Shipping\\ShippingServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "ext-intl": "*",
        "laravel/framework": "^11.0 || ^12.0",
        "mollie/mollie-api-php": "^3.0",
        "moneyphp/money": "^4.5",
        "pixelfear/composer-dist-plugin": "^0.1.0",
        "statamic/cms": "^6.5",
        "stillat/proteus": "^4.0",
        "stripe/stripe-php": "^16.4",
        "ext-zip": "*"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0",
        "spatie/ray": "^1.41.2"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    }
}
